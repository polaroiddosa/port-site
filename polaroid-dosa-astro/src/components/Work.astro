---
<section id="work">
  <div class="container">
    <div class="work-header reveal">
      <h2>The Work<br>Speaks First.</h2>
      <div class="work-filters">
        <button class="filter-btn active" data-filter="poster">Posters</button>
        <button class="filter-btn" data-filter="video">Films & Videos</button>
      </div>
    </div>
    <div class="work-grid reveal" id="workGrid">
      <!-- Work items injected by JS -->
    </div>
  </div>
</section>

<!-- Lightbox -->
<div class="lightbox" id="lightbox">
  <button class="lightbox-close" id="lightboxClose">BACK</button>
  <div class="lightbox-content" id="lightboxContent"></div>
</div>

<script>
  const STORAGE_KEY = 'pd_custom_works';
  const workGrid = document.getElementById('workGrid');
  const lightbox = document.getElementById('lightbox');
  const lightboxContent = document.getElementById('lightboxContent');
  const lightboxClose = document.getElementById('lightboxClose');

  const vimeoIds = [
    1187486935, 1187487079, 1187487059, 1187487036, 1187486968, 1187486910,
    1187486890, 1187486871, 1187486807, 1187486734, 1187486344, 1187485920,
    1187485968, 1187486021, 1187486286, 1187486242, 1187486074, 1187486573,
    1187486626, 1187486678
  ];

  function addVideoItem(id, type, customTitle = null) {
    const item = document.createElement('div');
    item.className = 'work-item video reveal';
    
    // Check if the current filter hides videos
    const activeBtn = document.querySelector('.filter-btn.active');
    if (activeBtn && activeBtn.dataset.filter !== 'all' && activeBtn.dataset.filter !== 'video') {
      item.style.display = 'none';
    }

    item.innerHTML = `<img src="" alt="Video" loading="lazy" decoding="async">
      <div class="play-btn"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div>
      <div class="work-overlay"><div class="work-tag">Brand Film</div><div class="work-title">...</div></div>`;
    
    const img = item.querySelector('img');
    img.onload = () => {
      img.classList.add('loaded');
      item.classList.add('loaded');
    };

    item.addEventListener('click', () => openLightbox(id, type));
    workGrid.appendChild(item);

    if (type === 'vimeo') {
      // Use vumbnail for instant reliable thumbnail loading
      item.querySelector('img').src = `https://vumbnail.com/${id}.jpg`;
      
      // Attempt to fetch title via oembed, fallback to generic title on CORS error
      fetch(`https://vimeo.com/api/oembed.json?url=https://vimeo.com/${id}&width=800`)
        .then(res => res.json())
        .then(data => { item.querySelector('.work-title').innerText = customTitle || data.title; })
        .catch(() => { item.querySelector('.work-title').innerText = customTitle || "Vimeo Video"; });
    } else {
      item.querySelector('img').src = `https://img.youtube.com/vi/${id}/maxresdefault.jpg`;
      item.querySelector('.work-title').innerText = customTitle || "YouTube Video";
    }
  }

  function addPosterItem(path, title) {
      const item = document.createElement('div');
      item.className = 'work-item poster reveal';
      item.innerHTML = `<img src="${path}" alt="${title}" loading="lazy" decoding="async">
        <div class="work-overlay"><div class="work-tag">Creative Work</div><div class="work-title">${title}</div></div>`;
      
      const img = item.querySelector('img');
      img.onload = () => {
        img.classList.add('loaded');
        item.classList.add('loaded');
      };
      // Force trigger for cached images
      if (img.complete) {
        img.classList.add('loaded');
        item.classList.add('loaded');
      }

      item.addEventListener('click', () => openLightbox(path, 'image'));
      workGrid.appendChild(item);
  }

  function openLightbox(id, type = 'vimeo') {
    let content = '';
    if (type === 'image') content = `<img src="${id}" style="width:100%; height:100%; object-fit:contain;">`;
    else if (type === 'vimeo') content = `<iframe src="https://player.vimeo.com/video/${id}?autoplay=1&color=FF6B00&title=0&byline=0&portrait=0" width="100%" height="100%" frameborder="0" allow="autoplay; fullscreen" allowfullscreen></iframe>`;
    else content = `<iframe src="https://www.youtube.com/embed/${id}?autoplay=1&rel=0" width="100%" height="100%" frameborder="0" allow="autoplay; fullscreen" allowfullscreen></iframe>`;
    lightboxContent.innerHTML = content;
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('active');
    lightboxContent.innerHTML = '';
    document.body.style.overflow = '';
  }

  if(lightboxClose) lightboxClose.addEventListener('click', closeLightbox);
  if(lightbox) lightbox.addEventListener('click', closeLightbox);
  window.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

